# PhotoPrism Configuration
PHOTOPRISM_SERVER_URL=https://your-photoprism-instance.com
PHOTOPRISM_USERNAME=your-username
PHOTOPRISM_PASSWORD=your-password

# Google Photos Configuration
GOOGLE_PHOTOS_ALBUM_NAME=Photoprism

# Photo Selection
# Number of random albums to select photos from
NUM_RANDOM_ALBUMS=3
# Total number of random photos to upload
NUM_RANDOM_PHOTOS=10

# Image Resizing (optional)
# Set to true to resize images before uploading (saves storage and bandwidth)
RESIZE_ENABLED=false
# Resize to this percentage of original dimensions (e.g. 80 = 80%). 100 = no resize
RESIZE_PERCENTAGE=100

# Scheduler Configuration
# Interval between sync runs in seconds (default: 86400 = 24 hours)
SCHEDULER_INTERVAL_SECONDS=86400

# ============================================
# Optional: Email Alerts
# ============================================
# Uncomment and configure to enable email notifications

#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USER=your-email@gmail.com
#SMTP_PASSWORD=your-app-password
#ALERT_EMAIL=recipient@example.com

# Note: For Gmail, create an App Password:
# https://support.google.com/accounts/answer/185833

# ============================================
# Optional: Slack Alerts
# ============================================
# Uncomment and configure to enable Slack notifications

#SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# To create a Slack webhook:
# 1. Go to https://api.slack.com/apps
# 2. Create a new app or select existing
# 3. Enable "Incoming Webhooks"
# 4. Add webhook to workspace
# 5. Copy the webhook URL

# ============================================
# Optional: Telegram Alerts
# ============================================
# Uncomment and configure to enable Telegram notifications

#TELEGRAM_BOT_TOKEN=your-bot-token
#TELEGRAM_CHAT_ID=your-chat-id

# To set up Telegram alerts:
# 1. Create a bot via @BotFather on Telegram
# 2. Copy the bot token
# 3. Start a chat with your bot
# 4. Get your chat ID from https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
